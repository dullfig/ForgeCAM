// ForgeCAM dark theme — color palette, spacing, typography tokens.
// Viewport stays dark regardless of theme. Chrome uses these tokens.

export global Theme {
    // ── Background layers ───────────────────────────────────────
    out property <color> bg-deep:    #0e1117;
    out property <color> bg-panel:   #161b22;
    out property <color> bg-surface: #1c2129;
    out property <color> bg-hover:   #252c35;
    out property <color> bg-active:  #2d353f;

    // ── Borders ─────────────────────────────────────────────────
    out property <color> border:       #2d333b;
    out property <color> border-light: #3d444d;

    // ── Text ────────────────────────────────────────────────────
    out property <color> text:        #c9d1d9;
    out property <color> text-dim:    #7d8590;
    out property <color> text-bright: #e6edf3;

    // ── Accent ──────────────────────────────────────────────────
    out property <color> accent:     #4493f8;
    out property <color> accent-dim: #1a3a5c;

    // ── Semantic ────────────────────────────────────────────────
    out property <color> green:      #3fb950;
    out property <color> green-dim:  #1a3d2a;
    out property <color> orange:     #d29922;
    out property <color> orange-dim: #3d2e1a;
    out property <color> red:        #f85149;

    // ── Spacing ─────────────────────────────────────────────────
    out property <length> spacing-xs: 4px;
    out property <length> spacing-sm: 8px;
    out property <length> spacing-md: 12px;
    out property <length> spacing-lg: 16px;
    out property <length> spacing-xl: 24px;

    // ── Typography ──────────────────────────────────────────────
    out property <length> font-xs:  10px;
    out property <length> font-sm:  11px;
    out property <length> font-md:  12px;
    out property <length> font-base: 13px;
    out property <length> font-lg:  16px;

    // ── Radii ───────────────────────────────────────────────────
    out property <length> radius:    6px;
    out property <length> radius-lg: 10px;

    // ── Panel sizes ─────────────────────────────────────────────
    out property <length> titlebar-height:  32px;
    out property <length> toolbar-height:   40px;
    out property <length> statusbar-height: 24px;
    out property <length> tab-height:       36px;
    out property <length> panel-header-height: 30px;
}
