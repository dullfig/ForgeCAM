// Properties panel — contextual detail for selected feature/operation.

import { Theme } from "theme.slint";
import { Slider } from "std-widgets.slint";

component PropSectionHeader inherits Rectangle {
    in property <string> label;

    height: 24px;
    background: transparent;

    HorizontalLayout {
        padding-left: 0;
        alignment: center;

        Text {
            text: root.label;
            color: Theme.text-dim;
            font-size: Theme.font-xs;
            font-weight: 600;
            letter-spacing: 0.4px;
        }
    }
}

component PropRow inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <color> value-color: Theme.text;
    in property <bool> editable: false;

    height: 24px;

    HorizontalLayout {
        spacing: Theme.spacing-sm;
        alignment: center;

        Text {
            text: root.label;
            color: Theme.text-dim;
            font-size: Theme.font-md;
            horizontal-stretch: 1;
        }

        if !root.editable: Text {
            text: root.value;
            color: root.value-color;
            font-size: Theme.font-sm;
            horizontal-stretch: 0;
        }

        if root.editable: Rectangle {
            width: 72px;
            height: 20px;
            border-radius: 4px;
            background: Theme.bg-surface;
            border-width: 1px;
            border-color: Theme.border;
            horizontal-stretch: 0;

            Text {
                text: root.value;
                color: Theme.text;
                font-size: Theme.font-sm;
                horizontal-alignment: right;
                vertical-alignment: center;
                x: 0;
                width: parent.width - 8px;
            }
        }
    }
}

component PropSection inherits VerticalLayout {
    in property <string> title;

    spacing: 0;

    PropSectionHeader { label: root.title; }

    @children
}

// Color swatch + brightness slider for gradient endpoints.
component ColorControl inherits HorizontalLayout {
    in property <string> label;
    in-out property <color> current-color;
    in-out property <float> brightness: 0.5;
    callback brightness-changed(float);

    spacing: Theme.spacing-sm;
    alignment: center;

    Text {
        text: root.label;
        color: Theme.text-dim;
        font-size: Theme.font-md;
        min-width: 50px;
    }

    // Color swatch
    Rectangle {
        width: 20px;
        height: 20px;
        border-radius: 4px;
        background: root.current-color;
        border-width: 1px;
        border-color: Theme.border-light;
    }

    // Brightness slider
    Slider {
        horizontal-stretch: 1;
        height: 20px;
        minimum: 0;
        maximum: 100;
        value: root.brightness * 100;
        changed(val) => {
            root.brightness = val / 100;
            root.brightness-changed(val / 100);
        }
    }
}

export component PropertiesPanel inherits Rectangle {
    // Gradient color properties — bound to App's gradient properties
    in-out property <color> gradient-top: #3d4a5c;
    in-out property <color> gradient-bottom: #080a10;

    background: Theme.bg-panel;

    VerticalLayout {
        // Panel header
        Rectangle {
            height: Theme.panel-header-height;
            background: Theme.bg-surface;

            HorizontalLayout {
                padding-left: Theme.spacing-md;
                spacing: 6px;
                alignment: center;

                Text { text: "⚙"; font-size: 12px; }
                Text {
                    text: "PROPERTIES";
                    color: Theme.text-dim;
                    font-size: Theme.font-xs;
                    font-weight: 600;
                    letter-spacing: 0.4px;
                }
            }
        }

        Rectangle { height: 1px; background: Theme.border; }

        // Content
        Flickable {
            vertical-stretch: 1;

            VerticalLayout {
                padding: Theme.spacing-md;
                spacing: Theme.spacing-sm;

                // Operation section
                PropSection {
                    title: "OP2 — ROUGH POCKET";

                    PropRow { label: "Type"; value: "2D Pocket"; }
                    PropRow { label: "Tool"; value: "T3 — 1/2\" Flat"; value-color: Theme.accent; }
                    PropRow { label: "Stepover"; value: "40%"; editable: true; }
                    PropRow { label: "Depth/Pass"; value: "0.125\""; editable: true; }
                    PropRow { label: "Stock Leave"; value: "0.010\""; editable: true; }
                    PropRow { label: "Spindle"; value: "8000"; editable: true; }
                    PropRow { label: "Feed"; value: "60.0"; editable: true; }
                    PropRow { label: "Plunge"; value: "20.0"; editable: true; }
                }

                Rectangle { height: 1px; background: Theme.border; }

                // Feature section
                PropSection {
                    title: "FEATURE — POCKET";

                    PropRow { label: "Depth"; value: "0.500\""; }
                    PropRow { label: "Corner R"; value: "0.125\""; }
                    PropRow { label: "Access"; value: "+Z (Top)"; }
                    PropRow { label: "Min Tool"; value: "∅ 0.250\""; }
                }

                Rectangle { height: 1px; background: Theme.border; }

                // Material section
                PropSection {
                    title: "MATERIAL";

                    PropRow { label: "Alloy"; value: "6061-T6"; }
                    PropRow { label: "Stock"; value: "4×3×1\""; }
                }

                Rectangle { height: 1px; background: Theme.border; }

                // Viewport gradient section
                PropSection {
                    title: "VIEWPORT";

                    ColorControl {
                        label: "Top";
                        current-color: root.gradient-top;
                    }

                    ColorControl {
                        label: "Bottom";
                        current-color: root.gradient-bottom;
                    }
                }
            }
        }
    }
}
